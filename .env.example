APP_NAME=clinical-intel-mcp
APP_ENV=dev
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=25
USER_AGENT=clinical-intel-mcp/0.2.0

GOOGLE_CLOUD_PROJECT=ai-hack26ham-402
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=True
VERTEX_GEMINI_MODEL=gemini-2.5-flash
ENABLE_VERTEX_WEB_SEARCH=true

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ENABLE_LLM_TOOL_ORCHESTRATION=true
OPENAI_ORCHESTRATOR_MODEL=gpt-5.4
OPENAI_ORCHESTRATOR_REASONING_EFFORT=high
OPENAI_ORCHESTRATOR_MAX_STEPS=10
OPENAI_ORCHESTRATOR_MAX_OUTPUT_TOKENS=18000
OPENAI_ORCHESTRATOR_TIMEOUT_SECONDS=300

ANSWER_CLINICAL_QUESTION_TIMEOUT_SECONDS=28
SEARCH_TRIALS_TOTAL_TIMEOUT_SECONDS=24
CLINICAL_TRIALS_SEARCH_TIMEOUT_SECONDS=12
CLINICAL_TRIAL_DETAILS_TIMEOUT_SECONDS=12
WEB_CONTEXT_TIMEOUT_SECONDS=20
MAX_TRIALS_TO_ENRICH_WITH_PUBLICATIONS=5
PER_TRIAL_PUBLICATION_LOOKUP_TIMEOUT_SECONDS=8

PUBLIC_BASE_URL=http://localhost:8080
